<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= STUDENT ================= -->
    <record id="school_student_tree_view" model="ir.ui.view">
        <field name="name">school.student.tree</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="roll_number"/>
                <field name="gender"/>
                <field name="classroom_id"/>
                <field name="parent_phone"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="school_student_form_view" model="ir.ui.view">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>

                    <group>
                        <group>
                            <field name="roll_number"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="classroom_id"/>
                        </group>
                        <group>
                            <field name="parent_name"/>
                            <field name="parent_phone"/>
                            <field name="address"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Photo">
                            <field name="image" widget="image" class="oe_avatar"/>
                        </page>
                    </notebook>

                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <!-- ================= TEACHER ================= -->
    <record id="school_teacher_tree_view" model="ir.ui.view">
        <field name="name">school.teacher.tree</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <list string="Teachers">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="specialization"/>
                <field name="phone"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="school_teacher_form_view" model="ir.ui.view">
        <field name="name">school.teacher.form</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>

                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="gender"/>
                            <field name="qualification"/>
                        </group>
                        <group>
                            <field name="specialization"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="joining_date"/>
                            <field name="salary"/>
                        </group>
                    </group>

                    <field name="image" widget="image" class="oe_avatar"/>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <!-- ================= CLASSROOM ================= -->
    <record id="school_classroom_tree_view" model="ir.ui.view">
        <field name="name">school.classroom.tree</field>
        <field name="model">school.classroom</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="section"/>
                <field name="class_teacher_id"/>
                <field name="total_students"/>
            </list>
        </field>
    </record>

    <record id="school_classroom_form_view" model="ir.ui.view">
        <field name="name">school.classroom.form</field>
        <field name="model">school.classroom</field>
        <field name="arch" type="xml">
            <form string="Classroom">
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>

                    <group>
                        <field name="section"/>
                        <field name="class_teacher_id"/>
                        <field name="total_students"/>
                    </group>

                    <notebook>
                        <page string="Students">
                            <field name="student_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="roll_number"/>
                                    <field name="gender"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    <!-- ================= FEE ================= -->
    <record id="school_fee_tree_view" model="ir.ui.view">
        <field name="name">school.fee.tree</field>
        <field name="model">school.fee</field>
        <field name="arch" type="xml">
            <list string="Fees">
                <field name="student_id"/>
                <field name="fee_type"/>
                <field name="amount"/>
                <field name="due_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="school_fee_form_view" model="ir.ui.view">
        <field name="name">school.fee.form</field>
        <field name="model">school.fee</field>
        <field name="arch" type="xml">
            <form string="Fee">
                <header>
                    <button name="action_mark_paid" type="object"
                            string="Mark as Paid"
                            class="btn-primary"
                            invisible="state == 'paid'"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="classroom_id"/>
                            <field name="fee_type"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="due_date"/>
                            <field name="payment_date"/>
                        </group>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <!-- ================= ACTIONS ================= -->
    <record id="school_student_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="school_teacher_action" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">school.teacher</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="school_classroom_action" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">school.classroom</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="school_fee_action" model="ir.actions.act_window">
        <field name="name">Fees</field>
        <field name="res_model">school.fee</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ================= MENUS ================= -->
    <menuitem id="school_main_menu"
              name="School Management"
              sequence="10"
              web_icon="school_management,static/description/icon.png"/>

    <menuitem id="school_students_menu"
              name="Students"
              parent="school_main_menu"
              action="school_student_action"
              sequence="10"/>

    <menuitem id="school_teachers_menu"
              name="Teachers"
              parent="school_main_menu"
              action="school_teacher_action"
              sequence="20"/>

    <menuitem id="school_classes_menu"
              name="Classes"
              parent="school_main_menu"
              action="school_classroom_action"
              sequence="30"/>

    <menuitem id="school_fees_menu"
              name="Fees"
              parent="school_main_menu"
              action="school_fee_action"
              sequence="40"/>

</odoo>